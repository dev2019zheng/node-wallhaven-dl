{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Wallhaven Desktop",
  "version": "0.1.0",
  "identifier": "cc.zhengyh.wallhaven.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wallhaven Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost https://w.wallhaven.cc https://th.wallhaven.cc; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/wallpapers/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility"
  }
}
